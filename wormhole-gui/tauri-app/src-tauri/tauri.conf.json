{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wormhole-gui",
  "mainBinaryName": "wormhole-gui",
  "version": "0.3.1",
  "identifier": "dev.lemon.wormhole-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wormhole-gui",
        "width": 480,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwODU1MDgwMDJDMjU0NjAKUldSZ1ZNSUNnRkNGd0FNV3ppMlY1b2pzeENidHcyVUwvTmxvSFloa3ExOGZ1clIxOFFkbWVjU2sK",
      "endpoints": [
        "https://lemond-dev.github.io/wormhole-gui/latest.json"
      ]
    }
  }
}
