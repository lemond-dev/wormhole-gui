{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wormhole-gui",
  "mainBinaryName": "wormhole-gui",
  "version": "0.2.5",
  "identifier": "dev.lemon.wormhole-gui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wormhole-gui",
        "width": 480,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
